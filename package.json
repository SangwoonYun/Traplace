{
  "name": "traplace",
  "type": "module",
  "private": true,
  "scripts": {
    "lint:js": "eslint \"app/static/js/**/*.js\"",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "vitest": {
    "environment": "jsdom",
    "include": ["tests/js/**/*.test.js"]
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^9.1.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.3.3",
    "vitest": "^4.1.5"
  }
}
